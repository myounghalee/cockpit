// Cockpit - Cycle 2 스키마
// 프로젝트를 1급 엔티티로 승격. 폴더(그룹)·즐겨찾기 추가.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ProjectFolder {
  id        String    @id @default(cuid())
  name      String
  order     Int       @default(0)
  collapsed Boolean   @default(false) // UI 접힘 상태 서버 저장 (sync across devices 대비)
  createdAt DateTime  @default(now())
  projects  Project[]

  @@index([order])
}

model Project {
  id           String         @id @default(cuid())
  name         String
  path         String         @unique
  folderId     String?
  folder       ProjectFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  isFavorite   Boolean        @default(false)
  order        Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  tickets      Ticket[]
  quickActions QuickAction[]
  memos        Memo[]

  @@index([folderId, order])
  @@index([isFavorite])
}

// ToDo / Memo — 아이디어·할 일·버그 메모장. 성숙하면 Ticket으로 승격.
// projectId가 null이면 전역 메모 (프로젝트에 매이지 않음).
model Memo {
  id           String    @id @default(cuid())
  projectId    String?
  project      Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title        String
  content      String    @default("")   // markdown
  tags         String    @default("")   // "아이디어,버그,개선" 콤마 구분
  pinnedAt     DateTime?                // 상단 고정 시 타임스탬프
  completedAt  DateTime?                // 완료 체크 시 타임스탬프 (TODO 성격)
  archivedAt   DateTime?                // 아카이브 시 타임스탬프 (정리용, 완료와 별개)
  convertedTicketId String? @unique     // 티켓으로 변환되면 해당 ticket.id 기록
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([projectId, archivedAt])
  @@index([projectId, completedAt])
  @@index([pinnedAt])
}

// Git 빠른 액션(워크플로우). projectId가 null이면 전역 프리셋.
// steps는 JSON 문자열. 형식은 TypeScript 쪽 Step 타입 참조.
model QuickAction {
  id        String   @id @default(cuid())
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  icon      String?
  steps     String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([projectId, order])
}

model Ticket {
  id                String   @id @default(cuid())
  projectId         String
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title             String
  description       String?
  type              String   @default("feature") // feature | bug | improvement | check
  successCriteria   String?
  jiraKey           String?
  sessionId         String?  // Claude Code 세션 재사용 id
  status            String   @default("backlog") // backlog | in_progress | review | done
  priority          Int      @default(0)
  order             Int      @default(0)
  startedAt         DateTime?
  completedAt       DateTime?
  reworkCount       Int      @default(0)
  lastReworkRequest String?
  resultSummary     String?  // 작업 결과 요약
  pdcaStage         String?  // null=일반 티켓, "plan"|"design"|"do"|"check"|"report"=PDCA 티켓 현재 단계
  autoMode          String   @default("manual")  // manual | after_plan | full
  commitMode        String   @default("none")    // none | commit | commit_push
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([projectId, status])
  @@index([jiraKey])
}

model Setting {
  key   String @id
  value String
}
